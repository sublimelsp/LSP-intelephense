{
    "input_repository_url": "https://github.com/bmewburn/vscode-intelephense",
    "input_repository_json_configuration_path": "package.json",
    "transformers": [
        {
            "type": "jq",
            "options": ".contributes.configuration.properties"
        },
        {
            "type": "jq",
            "options": "walk(if type == \"object\" and has(\"summary\") and (.summary | type == \"string\") then .summary |= gsub(\"\\\\$\"; \"\\\\$\") else . end)"
        },
        {
            "type": "jq",
            "options": "walk(if type == \"object\" and has(\"tags\") and (.tags | type == \"array\") then .tags |= map(if type == \"string\" then gsub(\"\\\\$\"; \"\\\\$\") else . end) else . end)"
        },
        {
            "type": "remove_keys",
            "options": [
                "intelephense.licenceKey",
                "intelephense.maxMemory",
                "intelephense.runtime",
                "intelephense.shortOpenEchoAutoClose",
                "intelephense.trace.server"
            ]
        },
        {
            "type": "prepend_keys",
            "options": {
                "statusText": {
                    "default": "{% if server_version %}v{{ server_version }}{% endif %}",
                    "markdownDescription": "The (Jinja2) template of the status bar text which is inside the parentheses `(...)`. See https://jinja.palletsprojects.com/templates/",
                    "type": "string"
                }
            }
        }
    ],
    "render_templates": [
        {
            "type": "settings",
            "template_path": "templates/sublime-settings.jinja.json",
            "output_path": "LSP-intelephense.sublime-settings"
        },
        {
            "type": "schema",
            "template_path": "templates/sublime-package.jinja.json",
            "output_path": "sublime-package.json"
        }
    ]
}
